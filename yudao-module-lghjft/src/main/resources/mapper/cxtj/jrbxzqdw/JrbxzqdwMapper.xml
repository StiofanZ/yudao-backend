    <!-- v1: selectJrbxzqdwVo — 3-table JOIN (jrbxzqdw + gh_hj + jrbxzqdwjfqk1 + jrbxzqdwjfqk) -->
    <sql id="selectJrbxzqdwVo">
        select
        t.id,
        t.dwdm,
        h.dept_id,
        t.shxydm,
        t.nsrsbh,
        t.nsrmc,
        t.djxh,
        t.zgjrghzgdwbz,
        h.xtlb_dm,
        h.ghlb_dm,
        t.nsrzt_dm,
        t.djzclx_dm,
        t.djzclxmc,
        t.scjydz,
        t.scjydzxzqhsz_dm,
        t.xzqhmc,
        t.jdxz_dm,
        t.hy_dm,
        t.hymc,
        t.djjg_dm,
        t.djjgmc,
        t.zgswj_dm,
        t.zgswjmc,
        t.zgswskfj_dm,
        t.zgksfjmc,
        t.cwfzrxm,
        t.cwfzrgddh,
        t.cwfzryddh,
        t.cyrs,
        t.bz,
        t.hsjg,
        t.create_by,
        t.create_time,
        t.update_by,
        t.update_time,
        b.gzze,
        b.bs,
        b.je,
        b.sl,
        k.bs2024,
        k.je2024,
        k.bs2023,
        k.je2023,
        k.bs2022,
        k.je2022,
        k.bs2021,
        k.je2021,
        k.bs2020,
        k.je2020
        from
        jrbxzqdw t
        left join gh_hj h on t.djxh = h.djxh
        left join jrbxzqdwjfqk1 b on t.djxh = b.djxh
        left join jrbxzqdwjfqk k on t.djxh = k.djxh
    </sql>

