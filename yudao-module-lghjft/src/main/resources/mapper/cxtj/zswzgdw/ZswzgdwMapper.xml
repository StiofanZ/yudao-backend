<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.iocoder.yudao.module.lghjft.dal.mysql.cxtj.zswzgdw.ZswzgdwMapper">

    <!-- v1: ZswzgdwResult (NO cascade) -->
    <resultMap type="cn.iocoder.yudao.module.lghjft.dal.dataobject.cxtj.zswzgdw.ZswzgdwDO" id="ZswzgdwResult">
        <result property="djxh"    column="djxh"    />
        <result property="id"      column="id"      />
        <result property="dwdm"    column="dwdm"    />
        <result property="deptId"  column="dept_id"  />
        <result property="zgswjDm" column="zgswj_dm" />
        <result property="shxydm"  column="shxydm"  />
        <result property="nsrmc"   column="nsrmc"   />
        <result property="bs"      column="bs"      />
        <result property="jfje"    column="jfje"    />
        <result property="jcghje"  column="jcghje"  />
        <result property="qrjgDm"  column="qrjg_dm" />
    </resultMap>

    <!-- v1: ZswzgdwZswzgdwQrResult (WITH cascade collection) -->
    <resultMap id="ZswzgdwZswzgdwQrResult" type="cn.iocoder.yudao.module.lghjft.dal.dataobject.cxtj.zswzgdw.ZswzgdwDO" extends="ZswzgdwResult">
        <collection property="zswzgdwQrList" notNullColumn="sub_djxh" javaType="java.util.List"
                    resultMap="ZswzgdwQrResult" />
    </resultMap>

    <resultMap type="cn.iocoder.yudao.module.lghjft.dal.dataobject.cxtj.zswzgdw.ZswzgdwQrDO" id="ZswzgdwQrResult">
        <result property="djxh"       column="sub_djxh"     />
        <result property="qrjgDm"     column="sub_qrjg_dm"  />
        <result property="bz"         column="bz"           />
        <result property="createBy"   column="create_by"    />
        <result property="createTime" column="create_time"  />
        <result property="updateBy"   column="update_by"    />
        <result property="updateTime" column="update_time"  />
    </resultMap>

    <!-- v1: selectZswzgdwVo — LEFT JOIN -->
    <sql id="selectZswzgdwVo">
        select a.djxh, a.id, a.dwdm, a.dept_id, a.zgswj_dm, a.shxydm, a.nsrmc, a.bs, a.jfje, a.jcghje,
        b.djxh as sub_djxh, b.qrjg_dm as sub_qrjg_dm, b.bz, b.create_by, b.create_time, b.update_by, b.update_time
        from zswzgdw a
        left join zswzgdw_qr b on b.djxh = a.djxh
    </sql>

    <!-- v1: selectZswzgdwList — paginated list (NO cascade, uses ZswzgdwResult) -->
    <select id="selectZswzgdwList" parameterType="cn.iocoder.yudao.module.lghjft.controller.admin.cxtj.zswzgdw.vo.ZswzgdwPageReqVO" resultMap="ZswzgdwResult">
        <include refid="selectZswzgdwVo"/>
        <where>
            <if test="djxh != null and djxh != ''"> and a.djxh = #{djxh}</if>
            <if test="id != null and id != ''"> and a.id = #{id}</if>
            <if test="dwdm != null and dwdm != ''"> and a.dwdm = #{dwdm}</if>
            <if test="deptId != null and deptId != ''"> and (a.dwdm = #{deptId} or a.dept_id = #{deptId})</if>
            <if test="zgswjDm != null and zgswjDm != ''"> and a.zgswj_dm = #{zgswjDm}</if>
            <if test="shxydm != null and shxydm != ''"> and a.shxydm = #{shxydm}</if>
            <if test="nsrmc != null and nsrmc != ''"> and a.nsrmc like concat('%', #{nsrmc}, '%')</if>
            <if test="bs != null"> and a.bs = #{bs}</if>
            <if test="jfje != null"> and a.jfje = #{jfje}</if>
            <if test="jcghje != null"> and a.jcghje = #{jcghje}</if>
            <if test="qrjgDm != null and qrjgDm != ''"> and b.qrjg_dm = #{qrjgDm}</if>
        </where>
    </select>

    <!-- v1: selectZswzgdwByDjxh — single WITH cascade (uses ZswzgdwZswzgdwQrResult) -->
    <select id="selectZswzgdwByDjxh" parameterType="String" resultMap="ZswzgdwZswzgdwQrResult">
        select a.djxh, a.id, a.dwdm, a.dept_id, a.zgswj_dm, a.shxydm, a.nsrmc, a.bs, a.jfje, a.jcghje,
        b.djxh as sub_djxh, b.qrjg_dm as sub_qrjg_dm, b.bz, b.create_by, b.create_time, b.update_by, b.update_time
        from zswzgdw a
        left join zswzgdw_qr b on b.djxh = a.djxh
        where a.djxh = #{djxh}
    </select>

    <!-- v1: insertZswzgdw -->
    <insert id="insertZswzgdw" parameterType="cn.iocoder.yudao.module.lghjft.dal.dataobject.cxtj.zswzgdw.ZswzgdwDO">
        insert into zswzgdw
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="djxh != null and djxh != ''">djxh,</if>
            <if test="id != null and id != ''">id,</if>
            <if test="dwdm != null">dwdm,</if>
            <if test="deptId != null">dept_id,</if>
            <if test="zgswjDm != null and zgswjDm != ''">zgswj_dm,</if>
            <if test="shxydm != null and shxydm != ''">shxydm,</if>
            <if test="nsrmc != null and nsrmc != ''">nsrmc,</if>
            <if test="bs != null">bs,</if>
            <if test="jfje != null">jfje,</if>
            <if test="jcghje != null">jcghje,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="djxh != null and djxh != ''">#{djxh},</if>
            <if test="id != null and id != ''">#{id},</if>
            <if test="dwdm != null">#{dwdm},</if>
            <if test="deptId != null">#{deptId},</if>
            <if test="zgswjDm != null and zgswjDm != ''">#{zgswjDm},</if>
            <if test="shxydm != null and shxydm != ''">#{shxydm},</if>
            <if test="nsrmc != null and nsrmc != ''">#{nsrmc},</if>
            <if test="bs != null">#{bs},</if>
            <if test="jfje != null">#{jfje},</if>
            <if test="jcghje != null">#{jcghje},</if>
        </trim>
    </insert>

    <!-- v1: updateZswzgdw — updates zswzgdw_qr table (V1 original behavior) -->
    <update id="updateZswzgdwQr" parameterType="cn.iocoder.yudao.module.lghjft.dal.dataobject.cxtj.zswzgdw.ZswzgdwDO">
        update zswzgdw_qr
        <trim prefix="set" suffixOverrides=",">
            <if test="djxh != null and djxh != ''">djxh = #{djxh},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
        </trim>
        where djxh = #{djxh}
    </update>

    <!-- v1: deleteZswzgdwByDjxh -->
    <delete id="deleteZswzgdwByDjxh" parameterType="String">
        delete from zswzgdw where djxh = #{djxh}
    </delete>

    <!-- v1: deleteZswzgdwByDjxhs — batch delete -->
    <delete id="deleteZswzgdwByDjxhs" parameterType="String">
        delete from zswzgdw where djxh in
        <foreach item="djxh" collection="array" open="(" separator="," close=")">
            #{djxh}
        </foreach>
    </delete>

    <!-- v1: deleteZswzgdwQrByDJXHs — batch delete qr by djxhs -->
    <delete id="deleteZswzgdwQrByDjxhs" parameterType="String">
        delete from zswzgdw_qr where djxh in
        <foreach item="djxh" collection="array" open="(" separator="," close=")">
            #{djxh}
        </foreach>
    </delete>

    <!-- v1: deleteZswzgdwQrByDJXH — delete qr by single djxh -->
    <delete id="deleteZswzgdwQrByDjxh" parameterType="String">
        delete from zswzgdw_qr where djxh = #{djxh}
    </delete>

    <!-- v1: batchZswzgdwQr — ON DUPLICATE KEY UPDATE -->
    <insert id="batchZswzgdwQr">
        insert into zswzgdw_qr(djxh, qrjg_dm, bz, create_by, create_time, update_by, update_time) values
        <foreach item="item" index="index" collection="list" separator=",">
            (#{item.djxh}, #{item.qrjgDm}, #{item.bz}, #{item.createBy}, #{item.createTime}, #{item.updateBy}, sysdate())
        </foreach>
        on duplicate key update
        djxh = values(djxh),
        qrjg_dm = values(qrjg_dm),
        bz = values(bz),
        create_by = values(create_by),
        create_time = values(create_time),
        update_by = values(update_by),
        update_time = values(update_time)
    </insert>
</mapper>
