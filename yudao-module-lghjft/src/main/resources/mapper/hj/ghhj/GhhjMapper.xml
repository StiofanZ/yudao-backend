    <!-- 批量删除户籍 -->
    <delete id="deleteGhHjBydjxhs">
        delete from gh_hj where djxh in
        <foreach item="djxh" collection="djxhs" open="(" separator="," close=")">
            #{djxh}
        </foreach>
    </delete>

    <!-- 根据纳税人关键字查询户籍列表(含部门名称) - 1:1 v1 getListByDjNsrxxDto -->
    <select id="getListByDjNsrxxDto" resultType="cn.iocoder.yudao.module.lghjft.controller.admin.hj.ghhj.vo.GhHjNsrxxResVO">
        select hj.dept_id as deptId, hj.djxh as djxh, hj.shxydm as shxydm, hj.nsrmc as nsrmc,
            d.dept_name as deptName
        from gh_hj hj
        left join sys_dept d on hj.dept_id = d.dept_id
        where 1 = 1
        <if test="searchNsrKey != null and searchNsrKey != ''">
            and ((hj.nsrsbh = #{searchNsrKey}) or
            (hj.nsrmc like concat('%', #{searchNsrKey}, '%')) or
            (hj.shxydm = #{searchNsrKey}))
        </if>
        <if test="djxh != null and djxh != ''">
            and hj.djxh = #{djxh}
        </if>
        <if test="shxydm != null and shxydm != ''">
            and hj.shxydm = #{shxydm}
        </if>
        union all
        select ds.dept_id as deptId, ds.djxh as djxh, ds.shxydm as shxydm, ds.nsrmc as nsrmc,
            d.dept_name as deptName
        from jhdwyds ds
        left join sys_dept d on ds.dept_id = d.dept_id
        where 1 = 1
        <if test="searchNsrKey != null and searchNsrKey != ''">
            and ((ds.shxydm = #{searchNsrKey}) or
            (ds.nsrmc like concat('%', #{searchNsrKey}, '%')))
        </if>
        <if test="djxh != null and djxh != ''">
            and ds.djxh = #{djxh}
        </if>
        <if test="shxydm != null and shxydm != ''">
            and ds.shxydm = #{shxydm}
        </if>
    </select>

    <!-- 根据 djxh 集合批量查询户籍记录 -->
    <select id="selectListByDjxhs" resultType="cn.iocoder.yudao.module.lghjft.controller.admin.hj.ghhj.vo.GhHjNsrxxResVO">
        select h.djxh as djxh, h.shxydm as shxydm, h.nsrmc as nsrmc,
            h.dept_id as deptId, h.lxdh as lxdh
        from gh_hj h
        where h.djxh in
        <foreach item="djxh" collection="djxhs" open="(" separator="," close=")">#{djxh}</foreach>
    </select>

    <!-- 根据用户标识集合查询可绑定的户籍记录 -->
    <select id="selectBindableByIdentifiers" resultType="cn.iocoder.yudao.module.lghjft.controller.admin.hj.ghhj.vo.GhHjNsrxxResVO">
        select h.djxh as djxh, h.shxydm as shxydm, h.nsrmc as nsrmc,
            h.dept_id as deptId, h.lxdh as lxdh
        from gh_hj h
        where h.shxydm in
        <foreach item="id" collection="ids" open="(" separator="," close=")">#{id}</foreach>
        or h.nsrsbh in
        <foreach item="id" collection="ids" open="(" separator="," close=")">#{id}</foreach>
        or h.lxdh in
        <foreach item="id" collection="ids" open="(" separator="," close=")">#{id}</foreach>
    </select>

