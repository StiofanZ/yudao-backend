    <!-- sql fragment: v1 where conditions (1:1 from GhHjMapper.xml selectGhHjList) -->
    <sql id="queryWhereConditions">
        <if test="query.hyghbz != null and query.hyghbz != ''">and hj.hyghbz = #{query.hyghbz}</if>
        <if test="query.djxh != null and query.djxh != ''">and hj.djxh = #{query.djxh}</if>
        <if test="query.shxydm != null and query.shxydm != ''">and hj.shxydm = #{query.shxydm}</if>
        <if test="query.nsrsbh != null and query.nsrsbh != ''">and hj.nsrsbh = #{query.nsrsbh}</if>
        <if test="query.nsrmc != null and query.nsrmc != ''">and hj.nsrmc like concat('%', #{query.nsrmc}, '%')</if>
        <if test="query.jdxzDm != null and query.jdxzDm != ''">and hj.jdxz_dm = #{query.jdxzDm}</if>
        <if test="query.zgswjmc != null and query.zgswjmc != ''">and hj.zgswjmc like concat('%', #{query.zgswjmc}, '%')</if>
        <if test="query.zgswskfjDm != null and query.zgswskfjDm != ''">and hj.zgswskfj_dm = #{query.zgswskfjDm}</if>
        <if test="query.zgswskfjmc != null and query.zgswskfjmc != ''">and hj.zgswskfjmc like concat('%', #{query.zgswskfjmc}, '%')</if>
        <if test="query.ssglyxm != null and query.ssglyxm != ''">and hj.ssglyxm = #{query.ssglyxm}</if>
        <if test="query.hymc != null and query.hymc != ''">and hj.hymc = #{query.hymc}</if>
        <if test="query.zcdz != null and query.zcdz != ''">and hj.zcdz like concat('%', #{query.zcdz}, '%')</if>
        <if test="query.lxr != null and query.lxr != ''">and hj.lxr = #{query.lxr}</if>
        <if test="query.lxdh != null and query.lxdh != ''">and hj.lxdh = #{query.lxdh}</if>
        <if test="query.clghbj != null and query.clghbj != ''">and hj.clghbj = #{query.clghbj}</if>
        <if test="query.beginClghrq != null and query.beginClghrq != '' and query.endClghrq != null and query.endClghrq != ''">
            and hj.clghrq between #{query.beginClghrq} and #{query.endClghrq}
        </if>
        <if test="query.ghlbDm != null and query.ghlbDm != ''">and hj.ghlb_dm = #{query.ghlbDm}</if>
        <if test="query.xtlbDm != null and query.xtlbDm != ''">and hj.xtlb_dm = #{query.xtlbDm}</if>
        <if test="query.jcghmc != null and query.jcghmc != ''">and hj.jcghmc like concat('%', #{query.jcghmc}, '%')</if>
        <if test="query.jcghzh != null and query.jcghzh != ''">and hj.jcghzh = #{query.jcghzh}</if>
        <if test="query.jcghhm != null and query.jcghhm != ''">and hj.jcghhm like concat('%', #{query.jcghhm}, '%')</if>
        <if test="query.jcghhh != null and query.jcghhh != ''">and hj.jcghhh = #{query.jcghhh}</if>
        <if test="query.jcghyh != null and query.jcghyh != ''">and hj.jcghyh like concat('%', #{query.jcghyh}, '%')</if>
        <if test="query.deptId != null and query.deptId != ''">and hj.dept_id = #{query.deptId}</if>
        <if test="query.hjfl8Dm != null and query.hjfl8Dm != ''">and hj.hjfl8_dm = #{query.hjfl8Dm}</if>
        <if test="query.hjfl9Dm != null and query.hjfl9Dm != ''">and hj.hjfl9_dm = #{query.hjfl9Dm}</if>
    </sql>

    <select id="selectGhHjBydjxh" parameterType="string" resultMap="GhHjVOMap">
        select <include refid="selectGhHjColumns"/>,
            d.dept_name as deptName
        from gh_hj hj
        left join sys_dept d on hj.dept_id = d.dept_id
        where hj.djxh = #{djxh}
    </select>

    <!-- v1: fushenPlBydjxhs updates jcghhm/jcghzh/jcghhh/jcghyhmc but is called with String[] from GET path.
         The v1 mapper expects #{jcghhm},#{jcghzh},#{jcghhh},#{jcghyhmc} from the array param which makes no sense.
         The actual v1 code only passes djxhs array. We keep v2 behavior: set hjfl9_dm='Y' as batch review mark. -->
    <update id="fushenPlBydjxhs">
        update gh_hj set hjfl9_dm = 'Y'
        where djxh in
        <foreach item="djxh" collection="djxhs" open="(" separator="," close=")">
            #{djxh}
        </foreach>
    </update>

    <!-- 户籍调拨: 1:1 from v1 updateAllocationGhHj -->
    <update id="updateAllocationGhHj">
        update gh_hj set dept_id = #{deptId}, hyghbz = #{hyghbz},
            jcghhm = null, jcghzh = null, jcghhh = null, jcghyh = null
        where djxh in
        <foreach item="djxh" collection="djxhs" open="(" separator="," close=")">
            #{djxh}
        </foreach>
    </update>

    <!-- 户籍管理分页查询 (1:1 v1 where conditions, order by update_time desc) -->
    <select id="selectGhHjPage" resultMap="GhHjVOMap">
        select <include refid="selectGhHjColumns"/>,
            d.dept_name as deptName
        from gh_hj hj
        left join sys_dept d on hj.dept_id = d.dept_id
        <where>
            <include refid="queryWhereConditions"/>
        </where>
        order by hj.update_time desc
    </select>

    <!-- 户籍管理列表查询（导出用） -->
    <select id="selectGhHjList" resultMap="GhHjVOMap">
        select <include refid="selectGhHjColumns"/>,
            d.dept_name as deptName
        from gh_hj hj
        left join sys_dept d on hj.dept_id = d.dept_id
        <where>
            <include refid="queryWhereConditions"/>
        </where>
        order by hj.update_time desc
    </select>

