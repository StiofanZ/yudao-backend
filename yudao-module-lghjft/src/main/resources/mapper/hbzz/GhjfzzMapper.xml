<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.iocoder.yudao.module.lghjft.dal.mysql.hbzz.ghjfzz.GhjfzzMapper">

    <resultMap type="cn.iocoder.yudao.module.lghjft.controller.admin.hbzz.ghjfzz.vo.GhjfzzResVO" id="GhjfzzResult">
        <result property="hkxxId" column="HKXX_ID"/>
        <result property="hkpch" column="HKPCH"/>
        <result property="xh" column="XH"/>
        <result property="lx" column="LX"/>
        <result property="zh" column="ZH"/>
        <result property="hm" column="HM"/>
        <result property="hh" column="HH"/>
        <result property="je" column="JE"/>
        <result property="deptId" column="dept_id"/>
        <result property="dz" column="DZ"/>
        <result property="fy" column="FY"/>
        <result property="jym" column="JYM"/>
        <result property="thbj" column="THBJ"/>
        <result property="thrq" column="THRQ"/>
        <result property="thyy" column="THYY"/>
        <result property="schkpch" column="SCHKPCH"/>
        <result property="bz" column="BZ"/>
        <result property="createBy" column="CREATE_BY"/>
        <result property="createTime" column="CREATE_TIME"/>
        <result property="updateBy" column="UPDATE_BY"/>
        <result property="updateTime" column="UPDATE_TIME"/>
        <result property="qrrq" column="QRRQ"/>
        <result property="dzbj" column="DZBJ"/>
        <result property="yhhdh" column="YHHDH"/>
    </resultMap>

    <!-- 子表映射（v1 GhjfQrszResult） -->
    <resultMap type="cn.iocoder.yudao.module.lghjft.controller.admin.hbzz.ghjfzz.vo.GhjfzzResVO$GhjfQrszItem" id="GhjfQrszResult">
        <result property="hkxxId" column="sub_HKXX_ID"/>
        <result property="ghHkxxJym" column="sub_GH_HKXX_JYM"/>
        <result property="dzbj" column="sub_DZBJ"/>
        <result property="qrrq" column="sub_QRRQ"/>
        <result property="yhhdh" column="sub_YHHDH"/>
        <result property="bz" column="sub_BZ"/>
        <result property="createBy" column="sub_CREATE_BY"/>
        <result property="createTime" column="sub_CREATE_TIME"/>
        <result property="updateBy" column="sub_UPDATE_BY"/>
        <result property="updateTime" column="sub_UPDATE_TIME"/>
    </resultMap>

    <!-- 主表+子表集合（v1 GhjfzzGhjfQrszResult） -->
    <resultMap id="GhjfzzDetailResult" type="cn.iocoder.yudao.module.lghjft.controller.admin.hbzz.ghjfzz.vo.GhjfzzResVO" extends="GhjfzzResult">
        <collection property="ghjfQrszList" notNullColumn="sub_HKXX_ID" javaType="java.util.List" resultMap="GhjfQrszResult"/>
    </resultMap>

    <!-- v1 selectGhjfzzVo（完全一致） -->
    <sql id="selectGhjfzzVo">
        select a.HKXX_ID,
               HKPCH,
               XH,
               LX,
               ZH,
               a.HM,
               a.HH,
               JE,
               a.dept_id,
               DZ,
               FY,
               a.JYM,
               THBJ,
               THRQ,
               THYY,
               SCHKPCH,
               a.bz,
               a.CREATE_BY,
               a.CREATE_TIME,
               a.UPDATE_BY,
               a.UPDATE_TIME,
               b.QRRQ,
               b.DZBJ,
               b.YHHDH,
               b.BZ          as sub_BZ,
               b.CREATE_BY   as sub_CREATE_BY,
               b.CREATE_TIME as sub_CREATE_TIME,
               b.UPDATE_BY   as sub_UPDATE_BY,
               b.UPDATE_TIME as sub_UPDATE_TIME
        from gh_hkxx a
                 left join gh_hkxx_qrsz b on b.HKXX_ID = a.HKXX_ID
    </sql>

    <!-- v1 selectGhjfzzList WHERE（完全一致） -->
    <select id="selectLegacyList" resultMap="GhjfzzResult">
        <include refid="selectGhjfzzVo"/>
        <where>
            (instr(a.fy,'工会费') > 0 or
            instr(a.fy,'工会经费') > 0 ) and a.fy not like '%返还基层%'
            and a.yxbj='Y'
            <if test="req.hkpch != null and req.hkpch != ''">and HKPCH = #{req.hkpch}</if>
            <if test="req.beginBfwjrq != null and req.beginBfwjrq != '' and req.endBfwjrq != null and req.endBfwjrq != ''">and MID(HKPCH,1,8) between #{req.beginBfwjrq} and
                #{req.endBfwjrq}
            </if>
            <if test="req.xh != null">and XH = #{req.xh}</if>
            <if test="req.beginQrrq != null and req.beginQrrq != '' and req.endQrrq != null and req.endQrrq != ''">and QRRQ between #{req.beginQrrq} and #{req.endQrrq}</if>
            <if test="req.dzbj != null">and DZBJ = #{req.dzbj}</if>
            <if test="req.yhhdh != null">and YHHDH = #{req.yhhdh}</if>
            <if test="req.lx != null and req.lx != ''">and LX = #{req.lx}</if>
            <if test="req.zh != null and req.zh != ''">and ZH in( #{req.zh},#{req.zh1},#{req.zh2},#{req.zh3})</if>
            <if test="req.hm != null and req.hm != ''">and HM like concat('%', #{req.hm}, '%')</if>
            <if test="req.hh != null and req.hh != ''">and HH = #{req.hh}</if>
            <if test="req.je != null">and JE = #{req.je}</if>
            <if test="req.deptId != null and req.deptId != ''">and dept_id = #{req.deptId}</if>
            <if test="req.dz != null and req.dz != ''">and DZ like concat('%', #{req.dz}, '%')</if>
            <if test="req.fy != null and req.fy != ''">and FY like concat('%', #{req.fy}, '%')</if>
            <if test="req.bz != null and req.bz != ''">and a.BZ like concat('%', #{req.bz}, '%')</if>
            <if test="req.jym != null and req.jym != ''">and JYM = #{req.jym}</if>
            <if test="req.thbj != null and req.thbj != ''">and THBJ = #{req.thbj}</if>
            <if test="req.beginThrq != null and req.beginThrq != '' and req.endThrq != null and req.endThrq != ''">and THRQ between #{req.beginThrq} and #{req.endThrq}</if>
            <if test="req.thyy != null and req.thyy != ''">and THYY = #{req.thyy}</if>
            <if test="req.schkpch != null and req.schkpch != ''">and SCHKPCH = #{req.schkpch}</if>
            <if test="req.createBy != null and req.createBy != ''">and CREATE_BY = #{req.createBy}</if>
            <if test="req.beginCreateTime != null and req.beginCreateTime != '' and req.endCreateTime != null and req.endCreateTime != ''">and CREATE_TIME between
                #{req.beginCreateTime} and #{req.endCreateTime}
            </if>
            <if test="req.updateBy != null and req.updateBy != ''">and UPDATE_BY = #{req.updateBy}</if>
            <if test="req.beginUpdateTime != null and req.beginUpdateTime != '' and req.endUpdateTime != null and req.endUpdateTime != ''">and UPDATE_TIME between
                #{req.beginUpdateTime} and #{req.endUpdateTime}
            </if>
        </where>
        order by hkpch desc
    </select>

    <!-- v1 selectGhjfzzByHkxxId（完全一致，返回子表集合） -->
    <select id="selectLegacyById" resultMap="GhjfzzDetailResult">
        select a.HKXX_ID,
               a.HKPCH,
               a.XH,
               a.LX,
               a.ZH,
               a.HM,
               a.HH,
               a.JE,
               a.dept_id,
               a.DZ,
               a.FY,
               a.JYM,
               a.THBJ,
               a.THRQ,
               a.THYY,
               a.SCHKPCH,
               a.bz,
               a.CREATE_BY,
               a.CREATE_TIME,
               a.UPDATE_BY,
               a.UPDATE_TIME,
               b.HKXX_ID     as sub_HKXX_ID,
               b.GH_HKXX_JYM as sub_GH_HKXX_JYM,
               b.QRRQ        as sub_QRRQ,
               b.DZBJ        as sub_DZBJ,
               b.YHHDH       as sub_YHHDH,
               b.BZ          as sub_BZ,
               b.CREATE_BY   as sub_CREATE_BY,
               b.CREATE_TIME as sub_CREATE_TIME,
               b.UPDATE_BY   as sub_UPDATE_BY,
               b.UPDATE_TIME as sub_UPDATE_TIME
        from gh_hkxx a
                 left join gh_hkxx_qrsz b on b.HKXX_ID = a.HKXX_ID
        where a.HKXX_ID = #{id}
    </select>

</mapper>
