    <select id="selectJcjfzzSummary" resultType="cn.iocoder.yudao.module.lghjft.controller.admin.hbzz.hkxx.vo.HkxxSummaryResVO">
        select count(1) as totalCount,
        ifnull(sum(t.je), 0) as totalAmount,
        ifnull(sum(t.confirmedFlag), 0) as confirmedCount,
        ifnull(sum(case when t.confirmedFlag = 1 then t.je else 0 end), 0) as confirmedAmount,
        ifnull(sum(t.returnedFlag), 0) as returnedCount,
        ifnull(sum(case when t.returnedFlag = 1 then t.je else 0 end), 0) as returnedAmount
        from (
        select a.HKXX_ID,
        max(a.JE) as je,
        max(case when ifnull(trim(b.DZBJ), '') not in ('', '0', 'N') then 1 else 0 end) as confirmedFlag,
        max(case when ifnull(trim(a.THBJ), '') not in ('', '0', 'N') then 1 else 0 end) as returnedFlag
        from gh_hkxx a
        left join gh_hkxx_qrsz b on b.HKXX_ID = a.HKXX_ID
        <include refid="selectJcjfzzWhere"/>
        group by a.HKXX_ID
        ) t
    </select>

