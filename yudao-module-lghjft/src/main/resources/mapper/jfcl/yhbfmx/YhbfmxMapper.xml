    <select id="getYhbfmx" resultMap="YhbfmxResultMap">
        SELECT * FROM gh_hkxx_yhbfmx WHERE bfzt='N'
        <if test="zh != null and zh != ''">
            and zh in
            <foreach collection="zh.split(',')" item="item" open="(" separator="," close=")">#{item}</foreach>
        </if>
        <if test="hm != null and hm != ''">
            and (
            <foreach item="item" collection="hm.split(',')" separator=" or ">
                hm like concat('%', #{item}, '%')
            </foreach>
            )
        </if>
        <if test="yt != null and yt != ''">
            and (
            <foreach item="item" collection="yt.split(',')" separator=" or ">
                yt like concat('%', #{item}, '%')
            </foreach>
            )
        </if>
        <if test="fy != null and fy != ''">
            and (
            <foreach item="item" collection="fy.split(',')" separator=" or ">
                fy like concat('%', #{item}, '%')
            </foreach>
            )
        </if>
        <if test="bfpch != null and '' != bfpch">and bfpch = #{bfpch}</if>
        <if test="bflx != null and '' != bflx">and bflx = #{bflx}</if>
        <if test="fclx != null and '' != fclx">and fclx = #{fclx}</if>
        <if test="deptId != null and deptId != ''">and dept_id = #{deptId}</if>
    </select>

    <select id="selectListByBfidStr" resultMap="YhbfmxResultMap">
        <include refid="selectYhbfmxVo"/>
        where bfid in
        <foreach item="bfid" collection="array" open="(" separator="," close=")">#{bfid}</foreach>
        order by bfid asc
    </select>

    <insert id="insertBatch" parameterType="java.util.List">
        INSERT INTO gh_hkxx_yhbfmx (
        hkxx_id, zh, hm, yhmc, sflhh, skrkhd, sfyjdz, sfyddh, rmb, fkfh, jsfs, ywzl, ffzh, ffjzzdy,
        qwr, qwsj, yt, je, dept_id, fy, hkpch, bfhzpch, bfpch, fclx, xh, UUID, bflx, bfzt, bfjg,
        thrq, bz, schzxx, YXBJ, ysthbj, ysthrq, ysthyy, yscjr, yscjsj, ysxgr, ysxgsj, CREATE_BY, CREATE_TIME, UPDATE_BY, UPDATE_TIME
        ) VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.hkxxId},#{item.zh},#{item.hm},#{item.yhmc},#{item.sflhh},#{item.skrkhd},#{item.sfyjdz},
            #{item.sfyddh},#{item.rmb},#{item.fkfh},#{item.jsfs},#{item.ywzl},#{item.ffzh},#{item.ffjzzdy},
            #{item.qwr},#{item.qwsj},#{item.yt},#{item.je},#{item.deptId},#{item.fy},#{item.hkpch},#{item.bfhzpch},
            #{item.bfpch},#{item.fclx},#{item.xh},#{item.uuid},#{item.bflx},#{item.bfzt},#{item.bfjg},#{item.thrq},
            #{item.bz},#{item.schzxx},#{item.yxbj},#{item.ysthbj},#{item.ysthrq},#{item.ysthyy},#{item.yscjr},
            #{item.yscjsj},#{item.ysxgr},#{item.ysxgsj},#{item.createBy},#{item.createTime},#{item.updateBy},#{item.updateTime})
        </foreach>
    </insert>

    <update id="updateBatchYhbfmx" parameterType="java.util.List">
        UPDATE gh_hkxx_yhbfmx
        <trim prefix="set" suffixOverrides=",">
            <trim prefix="bfhzpch =case" suffix="end,">
                <foreach collection="list" item="item">
                    <if test="item.bfhzpch != null">when bfid=#{item.bfid} then #{item.bfhzpch}</if>
                </foreach>
            </trim>
            <trim prefix="bfzt =case" suffix="end,">
                <foreach collection="list" item="item">
                    <if test="item.bfzt != null">when bfid=#{item.bfid} then #{item.bfzt}</if>
                </foreach>
            </trim>
            <trim prefix="bfjg =case" suffix="end,">
                <foreach collection="list" item="item">
                    <if test="item.bfjg != null">when bfid=#{item.bfid} then #{item.bfjg}</if>
                </foreach>
            </trim>
            <trim prefix="UPDATE_BY =case" suffix="end,">
                <foreach collection="list" item="item">
                    <if test="item.updateBy != null">when bfid=#{item.bfid} then #{item.updateBy}</if>
                </foreach>
            </trim>
            <trim prefix="UPDATE_TIME =case" suffix="end,">
                <foreach collection="list" item="item">
                    when bfid=#{item.bfid} then NOW()
                </foreach>
            </trim>
        </trim>
        WHERE bfid IN
        <foreach collection="list" item="item" open="(" separator="," close=")">#{item.bfid}</foreach>
    </update>

    <update id="updateYxbjByHkpch">
        UPDATE gh_hkxx_yhbfmx
        SET YXBJ = #{yxbj}, UPDATE_BY = #{updateBy}, UPDATE_TIME = NOW()
        WHERE YXBJ = 'Y'
        <if test="hkpch != null">and hkpch = #{hkpch}</if>
    </update>

