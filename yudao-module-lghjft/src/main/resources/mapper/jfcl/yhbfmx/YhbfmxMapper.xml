    <!-- ==================== 6. 业务专用方法 ==================== -->
    <select id="getYhbfmxJs" resultMap="YhbfmxResultMap">
        SELECT
            t.hkxx_id,
            t.zh,
            t.hm,
            ( SELECT MAX( wd.YHWDMC ) FROM dm_yhwd wd WHERE wd.WDHH = t.hh ) yhmc,
            t.hh AS sflhh,
            NULL AS skrkhd,
            NULL AS sfyjdz,
            NULL AS sfyddh,
            '人民币' AS rmb,
            NULL AS fkfh,
            '普通' AS jsfs,
            NULL AS ywzl,
            '841180069910001' AS ffzh,
            '00001' AS ffjzzdy,
            NULL AS qwr,
            NULL AS qwsj,
            t.FY AS yt,
            t.je AS je,
            t.dept_id as dept_id,
            CONCAT( t.DZ, T.FY ) AS FY,
            t.hkpch,
            NULL AS bfhzpch,
            concat(( curdate() + 0 ), '00001' ) AS bfpch,
            t.LX AS fclx,
            ROW_NUMBER () OVER () AS xh,
            UUID() UUID,
            '1' AS bflx,
            'N' AS bfzt,
            NULL AS thrq,
            NULL AS bz,
            'N' AS schzxx,
            'Y' AS YXBJ,
            t.THBJ AS ysthbj,
            t.THRQ AS ysthrq,
            t.THYY ysthyy,
            t.CREATE_BY AS yscjr,
            CREATE_TIME AS yscjsj,
            t.UPDATE_BY ysxgr,
            t.UPDATE_TIME ysxgsj,
            'SYSTEM' AS CREATE_BY,
            NOW() AS CREATE_TIME,
            'SYSTEM' AS UPDATE_BY,
            NOW() AS UPDATE_TIME
        FROM gh_hkxx t WHERE t.HKPCH = #{hkpch}
    </select>

