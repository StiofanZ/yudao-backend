            t.FY AS yt,
            t.je AS je,
            t.dept_id dept_id,
            CONCAT(t.DZ, T.FY) AS FY,
            t.hkpch,
            NULL AS bfhzpch,
            concat((curdate() + 0), '00001') AS bfpch,
            t.LX as fclx,
            ROW_NUMBER () OVER () AS xh,
            UUID() UUID,
            '3' AS bflx,
            'N' AS bfzt,
            NULL AS thrq,
            NULL AS bz,
