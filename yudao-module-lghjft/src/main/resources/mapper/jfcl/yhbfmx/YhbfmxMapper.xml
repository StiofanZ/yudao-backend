    <!-- 通用查询条件 -->
    <sql id="selectYhbfmxWhere">
        <where>
            <if test="req.hkxxId != null">and hkxx_id = #{req.hkxxId}</if>
            <if test="req.zh != null and req.zh != ''">
                and zh in
                <foreach collection="req.zh.split(',')" item="item" open="(" separator="," close=")">#{item}</foreach>
            </if>
            <if test="req.hm != null and req.hm != ''">
                and (
                <foreach item="item" collection="req.hm.split(',')" separator=" or ">hm like concat('%', #{item}, '%')</foreach>
                )
            </if>
            <if test="req.yhmc != null and req.yhmc != ''">and yhmc like concat('%', #{req.yhmc}, '%')</if>
            <if test="req.skrkhd != null and req.skrkhd != ''">and skrkhd = #{req.skrkhd}</if>
            <if test="req.sfyjdz != null and req.sfyjdz != ''">and sfyjdz = #{req.sfyjdz}</if>
