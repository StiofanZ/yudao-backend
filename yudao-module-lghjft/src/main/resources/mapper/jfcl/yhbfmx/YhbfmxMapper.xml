            <if test="req.yt != null and req.yt != ''">
                and (
                <foreach item="item" collection="req.yt.split(',')" separator=" or ">yt like concat('%', #{item}, '%')</foreach>
                )
            </if>
            <if test="req.je != null">and je = #{req.je}</if>
            <if test="req.sflhh != null and req.sflhh != ''">and sflhh = #{req.sflhh}</if>
            <if test="req.deptId != null and req.deptId != ''">and dept_id = #{req.deptId}</if>
            <if test="req.fy != null and req.fy != ''">
                and (
                <foreach item="item" collection="req.fy.split(',')" separator=" or ">fy like concat('%', #{item}, '%')</foreach>
                )
            </if>
            <if test="req.hkpch != null and req.hkpch != ''">and hkpch = #{req.hkpch}</if>
            <if test="req.bfhzpch != null and req.bfhzpch != ''">and bfhzpch = #{req.bfhzpch}</if>
            <if test="req.bfpch != null and req.bfpch != ''">and bfpch = #{req.bfpch}</if>
            <if test="req.fclx != null and req.fclx != ''">and fclx = #{req.fclx}</if>
            <if test="req.xh != null">and xh = #{req.xh}</if>
            <if test="req.uuid != null and req.uuid != ''">and UUID = #{req.uuid}</if>
            <if test="req.bflx != null and req.bflx != ''">and bflx = #{req.bflx}</if>
            <if test="req.bfzt != null and req.bfzt != ''">and bfzt = #{req.bfzt}</if>
            <if test="req.bfjg != null and req.bfjg != ''">and bfjg = #{req.bfjg}</if>
            <if test="req.beginThrq != null and req.beginThrq != '' and req.endThrq != null and req.endThrq != ''">
                and thrq between #{req.beginThrq} and #{req.endThrq}
            </if>
            <if test="req.bz != null and req.bz != ''">and bz = #{req.bz}</if>
            <if test="req.schzxx != null and req.schzxx != ''">and schzxx = #{req.schzxx}</if>
            <if test="req.yxbj != null and req.yxbj != ''">and YXBJ = #{req.yxbj}</if>
            <if test="req.ysthbj != null and req.ysthbj != ''">and ysthbj = #{req.ysthbj}</if>
            <!-- 2. 原始退回日期 -->
            <if test="req.beginYsthrq != null and req.beginYsthrq != '' and req.endYsthrq != null and req.endYsthrq != ''">
                and ysthrq between #{req.beginYsthrq} and #{req.endYsthrq}
            </if>
            <if test="req.ysthyy != null and req.ysthyy != ''">and ysthyy = #{req.ysthyy}</if>
            <if test="req.yscjr != null and req.yscjr != ''">and yscjr = #{req.yscjr}</if>
