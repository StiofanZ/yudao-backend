    <select id="getNsrdwxxWithAll" resultMap="NsrxxPayFormResultMap">
        SELECT
        HJ.DEPT_ID,
        HJ.SHXYDM,                          <!-- 社会信用代码 -->
        HJ.NSRMC,                           <!-- 申请汇总缴费单位全称 -->
--         HJ.ZGSWJ_DM AS ZGSWJMC,             <!-- 主管税务部门代码 -->
        HJ.ZCDZ,                            <!-- 注册地址 -->
        HJ.JCGHDM,                          <!-- 工会法人登记证件号码 -->
        HJ.JCGHMC,                          <!-- 缴费单位工会全称 -->
        HJ.ZGRS,                            <!-- 职工总人数 -->
        NULL AS GHHYTS,                     <!-- 工会会员数（无） -->
        HJ.LXR AS GHFZR,                      <!-- 工会负责人（无） -->
        HJ.ZGSWJMC,
        NULL AS CWFZRXM,                    <!-- 财务负责人（户籍表无，可留空） -->
        HJ.LXDH,                            <!-- 联系电话 -->
        HJ.JCGHZH AS JCGHZH,                <!-- 工会账户账号 -->
        HJ.JCGHYH AS JCGHYH,                <!-- 开户银行名称 -->
        HJ.JCGHHM AS JCGHHM,                <!-- 账户户名 -->
        HJ.JCGHHH AS JCGHHH,                <!-- 银行网点代码 -->
        HJ.NSRSBH,                          <!-- 纳税人识别号 -->

        HJ.DJXH,                            <!-- 登记序号 -->
        HJ.NSRZT_DM AS NSRZTDM,             <!-- 纳税人状态代码 -->
        HJ.JDXZ_DM AS JdXZDm,               <!-- 街道乡镇代码 -->
        HJ.ZGSWSKFJ_DM AS ZGSWSKFJDM        <!-- 科所分局代码 -->

        FROM
        gh_hj HJ  <!-- 直接从工会户籍表查询！！！ -->
        WHERE
        HJ.SHXYDM = #{shxydm,jdbcType=VARCHAR}
        LIMIT 1;
    </select>
            <!-- 新增：通用字典查询方法（适配银行、税务局等所有字典） -->
    <select id="getDictLabel" resultType="java.lang.String">
        SELECT label
        FROM system_dict_data
        WHERE dict_type = #{dictType}
          AND value = #{dictValue}
          AND status = '0'
          AND deleted = 0
            LIMIT 1;
    </select>
