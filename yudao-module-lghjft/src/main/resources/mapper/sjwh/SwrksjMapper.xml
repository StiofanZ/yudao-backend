            <if test="query.zgswjDm != null and query.zgswjDm != ''"> and zgswj_dm = #{query.zgswjDm}</if>
            <if test="query.zspmDm != null and query.zspmDm != ''"> and zspm_dm = #{query.zspmDm}</if>
            <if test="query.skssqq != null and query.skssqq != ''">and skssqq &gt;= #{query.skssqq}</if>
