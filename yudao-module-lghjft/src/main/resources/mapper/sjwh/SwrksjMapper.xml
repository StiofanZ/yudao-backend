    <sql id="selectSwrksjVo">
        select * from (
        select
        ghjf_id,
        spuuid,
        djxh,
        shxydm,
        nsrmc,
        nsrjc,
        dept_id,
        (select t.ghjg_dm from dm_swjg t where t.swjg_dm = j.zgswj_dm) dept_id1,
