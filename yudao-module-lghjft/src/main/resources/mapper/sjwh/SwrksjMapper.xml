        cbjthbj,
        cbjthrq,
        cbjthczy,
        jym,
        hkpch,
        bz,
        bluuid,
        sdghzh,
        sdghhm,
        sdghhh,
        sdghbl,
        sdghje,
        create_by,
        create_time,
        update_by,
        update_time
        from
        gh_jf j
        where
        j.dept_id = '000000'
        and j.zspm_dm != '399001910'
        and j.jsbj != 'T'
        and j.jsbj != 'S'
        and j.jsbj != 'Y'
        and j.jsbj != 'J'
        and j.djxh not in (select djxh from gh_hj)) a
    </sql>

    <select id="selectSwrksjPage" resultMap="SwrksjResult">
        <include refid="selectSwrksjVo"/>
        <where>
            <if test="query.spuuid != null and query.spuuid != ''"> and spuuid = #{query.spuuid}</if>
            <if test="query.djxh != null and query.djxh != ''"> and djxh = #{query.djxh}</if>
            <if test="query.shxydm != null and query.shxydm != ''"> and shxydm = #{query.shxydm}</if>
            <if test="query.nsrmc != null and query.nsrmc != ''"> and nsrmc like concat('%', #{query.nsrmc}, '%')</if>
            <if test="query.deptId != null and query.deptId != ''"> and dept_id1 = #{query.deptId}</if>
            <if test="query.zgswjDm != null and query.zgswjDm != ''"> and zgswj_dm = #{query.zgswjDm}</if>
            <if test="query.zspmDm != null and query.zspmDm != ''"> and zspm_dm = #{query.zspmDm}</if>
            <if test="query.skssqq != null and query.skssqq != ''">and skssqq &gt;= #{query.skssqq}</if>
            <if test="query.skssqz != null and query.skssqz != ''">and skssqz &lt;= #{query.skssqz}</if>
            <if test="query.rkrqq != null and query.rkrqq != '' and query.rkrqz != null and query.rkrqz != ''">and rkrq between #{query.rkrqq} and #{query.rkrqz}</if>
            <if test="query.jsbj != null and query.jsbj != ''"> and jsbj = #{query.jsbj}</if>
        </where>
        order by ghjf_id desc
    </select>

